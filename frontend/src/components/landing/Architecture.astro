<!-- Architecture: 4-layer diagram + tech badges -->
<section id="arquitectura" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center max-w-3xl mx-auto mb-14 fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-eco-text-primary mb-4">
        Arquitectura de 4 capas
      </h2>
      <p class="text-lg text-eco-text-secondary">
        Cada capa opera de forma independiente. Si una falla, las demas siguen funcionando.
      </p>
    </div>

    <!-- Layer diagram -->
    <div class="max-w-3xl mx-auto flex flex-col gap-0 mb-14 fade-up">
      <!-- Layer 4 (top) - Presentation -->
      <div class="bg-eco-green text-white rounded-t-xl p-5 sm:p-6">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs font-bold bg-white/20 px-2 py-0.5 rounded">CAPA 4</span>
          <span class="font-semibold">Presentacion</span>
        </div>
        <p class="text-sm text-white/80">Dashboard operativo + App del conductor (PWA) + App ciudadana</p>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center -my-1 z-10">
        <svg class="w-5 h-5 text-eco-green-dark" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </div>

      <!-- Layer 3 - AI -->
      <div class="bg-eco-green-light/20 border-x border-eco-green/20 p-5 sm:p-6">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs font-bold bg-eco-green/10 text-eco-green px-2 py-0.5 rounded">CAPA 3</span>
          <span class="font-semibold text-eco-text-primary">IA + Optimizacion</span>
        </div>
        <p class="text-sm text-eco-text-secondary">OR-Tools (TSP) + MLPRegressor (prediccion) + IBM Watsonx (lenguaje natural)</p>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center -my-1 z-10">
        <svg class="w-5 h-5 text-eco-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </div>

      <!-- Layer 2 - Cloud -->
      <div class="bg-green-50 border-x border-eco-green/20 p-5 sm:p-6">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs font-bold bg-eco-green/10 text-eco-green px-2 py-0.5 rounded">CAPA 2</span>
          <span class="font-semibold text-eco-text-primary">Procesamiento en la nube</span>
        </div>
        <p class="text-sm text-eco-text-secondary">FastAPI + PostgreSQL/PostGIS + IBM Cloud</p>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center -my-1 z-10">
        <svg class="w-5 h-5 text-eco-green" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </div>

      <!-- Layer 1 (bottom) - Data capture -->
      <div class="bg-green-50/60 border border-eco-green/20 rounded-b-xl p-5 sm:p-6">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs font-bold bg-eco-green/10 text-eco-green px-2 py-0.5 rounded">CAPA 1</span>
          <span class="font-semibold text-eco-text-primary">Captura de datos</span>
        </div>
        <p class="text-sm text-eco-text-secondary">Sensores IoT (50 contenedores, 3 zonas) + Reportes ciudadanos (app movil) + Datos historicos</p>
      </div>
    </div>

    <!-- Tech badges -->
    <div class="flex flex-wrap justify-center gap-3 fade-up">
      {['Astro 6', 'Tailwind 4', 'FastAPI', 'PostgreSQL + PostGIS', 'IBM Watsonx', 'OR-Tools', 'scikit-learn', 'Docker', 'Cloudflare Pages'].map(tech => (
        <span class="text-sm bg-eco-bg-header text-eco-text-secondary px-3 py-1.5 rounded-lg border border-eco-border">
          {tech}
        </span>
      ))}
    </div>
  </div>
</section>
