<!-- Impact metrics section with count-up animation -->
<section id="metricas" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center max-w-3xl mx-auto mb-14 fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-eco-text-primary mb-4">
        Impacto medible desde el primer dia
      </h2>
      <p class="text-lg text-eco-text-secondary">
        Resultados estimados con una flota de 20 camiones en 3 zonas de la CDMX.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-8" id="metrics-grid">
      <!-- Metric 1: km -->
      <div class="text-center fade-up">
        <div class="w-10 h-10 mx-auto mb-3 bg-green-50 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181"/>
          </svg>
        </div>
        <span class="block text-4xl sm:text-5xl font-bold text-eco-green" data-count="25" data-suffix="%">0%</span>
        <span class="block text-sm text-eco-text-secondary mt-1">menos kilometros recorridos</span>
        <span class="block text-xs text-eco-text-secondary mt-1">120 km/dia evitados vs ruta estandar</span>
      </div>

      <!-- Metric 2: CO2 -->
      <div class="text-center fade-up" style="animation-delay:.1s">
        <div class="w-10 h-10 mx-auto mb-3 bg-green-50 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
          </svg>
        </div>
        <span class="block text-4xl sm:text-5xl font-bold text-eco-green" data-count="129" data-suffix=" kg">0 kg</span>
        <span class="block text-sm text-eco-text-secondary mt-1">de CO2 evitados por dia</span>
        <span class="block text-xs text-eco-text-secondary mt-1">Equivalente a 2,350 arboles por ano</span>
      </div>

      <!-- Metric 3: savings -->
      <div class="text-center fade-up" style="animation-delay:.2s">
        <div class="w-10 h-10 mx-auto mb-3 bg-green-50 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <span class="block text-4xl sm:text-5xl font-bold text-eco-green" data-count="432" data-prefix="$" data-suffix="K">$0K</span>
        <span class="block text-sm text-eco-text-secondary mt-1">MXN de ahorro anual en combustible</span>
        <span class="block text-xs text-eco-text-secondary mt-1">48 litros de diesel ahorrados al dia</span>
      </div>

      <!-- Metric 4: speed -->
      <div class="text-center fade-up" style="animation-delay:.3s">
        <div class="w-10 h-10 mx-auto mb-3 bg-green-50 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <span class="block text-4xl sm:text-5xl font-bold text-eco-green" data-count="5" data-prefix="< " data-suffix="s">< 0s</span>
        <span class="block text-sm text-eco-text-secondary mt-1">para generar una ruta optimizada</span>
        <span class="block text-xs text-eco-text-secondary mt-1">2s optimizacion + 3s instrucciones IA</span>
      </div>
    </div>

    <p class="text-center text-xs text-eco-text-secondary max-w-2xl mx-auto fade-up">
      Escenario base: 20 camiones, 3 zonas, 50% de ocupacion promedio. Fuentes: SEDEMA, INECC, calculos propios con factor de emision 2.68 kg CO2/litro diesel (EPA).
    </p>
  </div>
</section>

<script>
  const grid = document.getElementById('metrics-grid');
  if (grid) {
    let animated = false;
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !animated) {
        animated = true;
        grid.querySelectorAll('[data-count]').forEach(el => {
          const target = parseInt(el.getAttribute('data-count')!);
          const prefix = el.getAttribute('data-prefix') || '';
          const suffix = el.getAttribute('data-suffix') || '';
          let current = 0;
          const step = Math.max(1, Math.ceil(target / 50));
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = prefix + current + suffix;
          }, 25);
        });
      }
    }, { threshold: 0.3 });
    observer.observe(grid);
  }
</script>
