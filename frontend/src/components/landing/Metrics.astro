---
---
<section id="metricas" class="mx-auto mt-32 max-w-7xl px-6 sm:mt-56 lg:px-8">
  <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
    <h2 class="text-base/7 font-semibold text-eco-green">Impacto medible</h2>
    <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl">Resultados desde el primer dia</p>
    <p class="mt-6 text-lg/8 text-gray-600">Resultados estimados con una flota de 20 camiones en 3 zonas de la CDMX.</p>
  </div>

  <dl class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-10 text-gray-900 sm:mt-20 sm:grid-cols-2 sm:gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-4" id="metrics-grid">
    <div class="flex flex-col gap-y-3 border-l border-eco-green/30 pl-6">
      <dt class="text-sm/6 text-gray-600">menos kilometros recorridos</dt>
      <dd class="order-first text-3xl font-semibold tracking-tight" data-count="25" data-suffix="%">0%</dd>
      <dd class="text-xs text-gray-400">120 km/dia evitados vs ruta estandar</dd>
    </div>
    <div class="flex flex-col gap-y-3 border-l border-eco-green/30 pl-6">
      <dt class="text-sm/6 text-gray-600">de CO2 evitados por dia</dt>
      <dd class="order-first text-3xl font-semibold tracking-tight" data-count="129" data-suffix=" kg">0 kg</dd>
      <dd class="text-xs text-gray-400">Equivalente a 2,350 arboles por ano</dd>
    </div>
    <div class="flex flex-col gap-y-3 border-l border-eco-green/30 pl-6">
      <dt class="text-sm/6 text-gray-600">MXN de ahorro anual en combustible</dt>
      <dd class="order-first text-3xl font-semibold tracking-tight" data-count="432" data-prefix="$" data-suffix="K">$0K</dd>
      <dd class="text-xs text-gray-400">48 litros de diesel ahorrados al dia</dd>
    </div>
    <div class="flex flex-col gap-y-3 border-l border-eco-green/30 pl-6">
      <dt class="text-sm/6 text-gray-600">para generar una ruta optimizada</dt>
      <dd class="order-first text-3xl font-semibold tracking-tight" data-count="5" data-prefix="< " data-suffix="s">&lt; 0s</dd>
      <dd class="text-xs text-gray-400">2s optimizacion + 3s instrucciones IA</dd>
    </div>
  </dl>

  <p class="mt-10 text-xs text-gray-400 max-w-2xl">Escenario base: 20 camiones, 3 zonas, 50% de ocupacion promedio. Fuentes: SEDEMA, INECC, calculos propios con factor de emision 2.68 kg CO2/litro diesel (EPA).</p>
</section>

<script>
  const grid = document.getElementById('metrics-grid');
  if (grid) {
    let animated = false;
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !animated) {
        animated = true;
        grid.querySelectorAll('[data-count]').forEach(el => {
          const target = parseInt(el.getAttribute('data-count')!);
          const prefix = el.getAttribute('data-prefix') || '';
          const suffix = el.getAttribute('data-suffix') || '';
          let current = 0;
          const step = Math.max(1, Math.ceil(target / 50));
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = prefix + current + suffix;
          }, 25);
        });
      }
    }, { threshold: 0.3 });
    observer.observe(grid);
  }
</script>
