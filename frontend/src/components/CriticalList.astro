---
/**
 * Critical containers panel. At scale (thousands of critical containers)
 * the full list would blow out the DOM, so we render only the top N
 * inside an internal scroll container and show the total count in the
 * header.
 */
---

<div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
  <div class="flex items-center justify-between gap-3">
    <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">
      Contenedores críticos
    </h2>
    <span id="critical-count-badge"
          class="text-xs font-medium text-eco-danger bg-eco-bg-header px-2 py-0.5 rounded-full">
      —
    </span>
  </div>
  <p id="critical-hint" class="text-xs text-eco-text-secondary">
    Mostrando los más urgentes. Haz scroll para ver más.
  </p>
  <ul id="critical-list" class="flex flex-col gap-2 max-h-96 overflow-y-auto pr-1">
    <li class="text-xs text-eco-text-secondary">Cargando...</li>
  </ul>
</div>

<script>
  const CRITICAL_PAGE_SIZE = 50;

  async function loadCritical() {
    const list = document.getElementById('critical-list')!;
    const badge = document.getElementById('critical-count-badge')!;
    const hint = document.getElementById('critical-hint')!;
    try {
      const url = `${window.__API__}/api/v1/containers/critical`
        + `?threshold=0.8&limit=${CRITICAL_PAGE_SIZE}&offset=0`;
      const res = await fetch(url);
      const data = await res.json();
      const total: number = data.total ?? 0;
      const containers: any[] = data.containers ?? [];

      badge.textContent = `${total.toLocaleString('es-MX')} críticos`;

      if (containers.length === 0) {
        hint.textContent = '';
        list.innerHTML = '<li class="text-xs text-eco-text-secondary">Sin contenedores críticos</li>';
        return;
      }

      if (total > containers.length) {
        hint.textContent = `Mostrando los ${containers.length} más urgentes de ${total.toLocaleString('es-MX')} críticos.`;
      } else {
        hint.textContent = `Todos los contenedores críticos (${total}).`;
      }

      // Containers are already sorted desc by fill_level from the API.
      list.innerHTML = containers.map(c => {
        const pct = Math.round(c.fill_level * 100);
        const barColor = pct >= 90 ? 'bg-eco-danger' : 'bg-eco-warning';
        return `
          <li class="flex items-center gap-2 text-sm">
            <span class="font-medium w-24 shrink-0 text-eco-text-primary truncate">${c.container_id}</span>
            <div class="flex-1 h-2 bg-eco-border rounded-full overflow-hidden">
              <div class="${barColor} h-full rounded-full" style="width:${pct}%"></div>
            </div>
            <span class="text-xs text-eco-text-secondary w-10 text-right shrink-0">${pct}%</span>
            <span class="text-xs text-eco-text-secondary w-28 text-right truncate shrink-0 capitalize">${(c.zone || '').replace(/_/g, ' ')}</span>
          </li>`;
      }).join('');
    } catch {
      list.innerHTML = '<li class="text-xs text-eco-danger">Error al cargar datos</li>';
    }
  }

  loadCritical();
  setInterval(loadCritical, 30_000);
</script>
