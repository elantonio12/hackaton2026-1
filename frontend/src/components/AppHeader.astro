---
/**
 * Shared app header for authenticated pages (admin, recolector, usuario).
 *
 * Props:
 *   title      - Page title shown after branding
 *   backHref   - Optional back-link target (shows arrow button on mobile)
 *   nav        - Optional array of { href, label } for sub-navigation
 */
interface NavLink {
  href: string;
  label: string;
}
interface Props {
  title?: string;
  backHref?: string;
  nav?: NavLink[];
}

const { title, backHref, nav } = Astro.props;
---

<header class="sticky top-0 z-20 bg-eco-bg-panel border-b border-eco-border">
  <div class="px-4 py-3 flex items-center justify-between gap-3">
    <!-- Left: back + brand + title -->
    <div class="flex items-center gap-2 min-w-0">
      {backHref && (
        <a href={backHref} class="text-eco-text-secondary hover:text-eco-text-primary shrink-0" aria-label="Volver">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
      )}
      <a href="/" class="flex items-center gap-2 shrink-0">
        <svg class="size-6 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
        </svg>
        <span class="font-semibold text-eco-text-primary">EcoRuta</span>
      </a>
      {title && (
        <>
          <span class="text-eco-text-secondary hidden sm:inline">/</span>
          <span class="text-sm text-eco-text-secondary truncate hidden sm:inline">{title}</span>
        </>
      )}
    </div>

    <!-- Right: user dropdown -->
    <div class="flex items-center gap-2">
      <el-dropdown class="relative inline-block text-left">
        <button type="button" class="flex items-center gap-2 rounded-full bg-eco-bg hover:bg-eco-bg-header border border-eco-border px-2 py-1 transition-colors">
          <span id="user-avatar" class="size-7 rounded-full bg-eco-green text-white font-semibold text-xs flex items-center justify-center">?</span>
          <span id="user-name" class="text-sm text-eco-text-primary hidden sm:inline">Usuario</span>
          <svg class="size-4 text-eco-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <el-menu anchor="bottom end" popover="manual" class="[--anchor-gap:8px] w-56 rounded-xl bg-white ring-1 ring-gray-900/10 shadow-lg p-1 text-sm transition transition-discrete data-closed:opacity-0 data-enter:duration-100 data-leave:duration-75">
          <div class="px-3 py-2 border-b border-eco-border">
            <p id="dropdown-name" class="font-semibold text-eco-text-primary truncate">—</p>
            <p id="dropdown-email" class="text-xs text-eco-text-secondary truncate">—</p>
            <p id="dropdown-role" class="text-xs text-eco-green font-medium capitalize mt-1">—</p>
          </div>
          <button id="logout-btn" type="button" class="w-full flex items-center gap-2 rounded-lg px-3 py-2 text-eco-danger hover:bg-red-50 focus:bg-red-50 focus:outline-none">
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Cerrar sesion
          </button>
        </el-menu>
      </el-dropdown>
    </div>
  </div>

  <!-- Optional sub-nav -->
  {nav && nav.length > 0 && (
    <nav class="px-4 border-t border-eco-border overflow-x-auto">
      <ul class="flex gap-1 min-w-max">
        {nav.map(link => (
          <li>
            <a href={link.href} data-nav-href={link.href} class="nav-link inline-block px-3 py-2.5 text-sm font-medium text-eco-text-secondary border-b-2 border-transparent hover:text-eco-text-primary whitespace-nowrap">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}
</header>

<script>
  import { getUser, apiLogout, isAuthenticated } from '../lib/api';

  // Guard: redirect to login if not authenticated
  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  } else {
    const user = getUser();
    if (user) {
      const name = (user.name as string) || 'Usuario';
      const email = (user.email as string) || '';
      const role = (user.role as string) || 'citizen';
      const initials = name.split(' ').slice(0, 2).map(s => s[0] || '').join('').toUpperCase() || '?';

      const avatarEl = document.getElementById('user-avatar');
      const nameEl = document.getElementById('user-name');
      const ddName = document.getElementById('dropdown-name');
      const ddEmail = document.getElementById('dropdown-email');
      const ddRole = document.getElementById('dropdown-role');

      if (avatarEl) avatarEl.textContent = initials;
      if (nameEl) nameEl.textContent = name.split(' ')[0]; // first name only
      if (ddName) ddName.textContent = name;
      if (ddEmail) ddEmail.textContent = email;
      if (ddRole) ddRole.textContent = role;
    }
  }

  // Logout handler
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    try {
      await apiLogout();
    } catch {
      // swallow — clear client-side state anyway
    }
    window.location.href = '/auth/login';
  });

  // Highlight active nav link by matching current pathname
  const currentPath = window.location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
    const href = link.dataset.navHref;
    if (href && currentPath === href) {
      link.classList.remove('text-eco-text-secondary', 'border-transparent');
      link.classList.add('text-eco-green', 'border-eco-green');
    }
  });
</script>
