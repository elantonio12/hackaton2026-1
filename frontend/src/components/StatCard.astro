---
interface Props {
  label: string;
  value: string | number;
  sub?: string;
  color?: 'default' | 'danger' | 'warning' | 'success' | 'info';
  icon?: string;
  trend?: string;
  id?: string;
}

const { label, value, sub, color = 'default', icon, trend, id } = Astro.props;

const valueClass = {
  default: 'text-eco-text-primary',
  danger:  'text-eco-danger',
  warning: 'text-eco-warning',
  success: 'text-eco-green',
  info:    'text-eco-info',
}[color];

const trendClass = {
  default: 'text-eco-text-secondary',
  danger:  'text-eco-danger',
  warning: 'text-eco-warning',
  success: 'text-eco-green',
  info:    'text-eco-info',
}[color];
---

<div {id} class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
  <div class="flex items-center justify-between">
    <span class="text-xs text-eco-text-secondary uppercase tracking-wide">{label}</span>
    {icon && (
      <svg class="w-4 h-4 text-eco-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    )}
  </div>
  <span class={`text-3xl font-medium ${valueClass}`}>{value}</span>
  <div class="flex items-center justify-between">
    {sub && <span class="text-xs text-eco-text-secondary">{sub}</span>}
    {trend && <span class={`text-xs font-medium ${trendClass}`}>{trend}</span>}
  </div>
</div>