---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import MapView from '../../components/MapView.astro';
import CriticalList from '../../components/CriticalList.astro';
import RouteList from '../../components/RouteList.astro';
import ReportList from '../../components/ReportList.astro';
import { adminNav } from '../../lib/nav';
---

<Layout title="Dashboard" requiredRole="admin">
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Dashboard" nav={adminNav} />

    <main class="max-w-6xl mx-auto px-4 py-5 flex flex-col gap-5">

      <!-- Metricas fila 1: sistema -->
      <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Contenedores</span>
          <span class="text-3xl font-semibold text-eco-text-primary" id="val-total">—</span>
          <span class="text-xs text-eco-text-secondary" id="sub-total">cargando...</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Criticos ahora</span>
          <span class="text-3xl font-semibold text-eco-danger" id="val-critical">—</span>
          <span class="text-xs text-eco-text-secondary">umbral 80%</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Llenos en 24h</span>
          <span class="text-3xl font-semibold text-eco-warning" id="val-predicted">—</span>
          <span class="text-xs text-eco-text-secondary">prediccion IA</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Recolectores</span>
          <span class="text-3xl font-semibold text-eco-green" id="val-collectors">—</span>
          <span class="text-xs text-eco-text-secondary" id="sub-collectors">cargando...</span>
        </div>
      </section>

      <!-- Metricas fila 2: eficiencia e impacto -->
      <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Combustible ahorrado</span>
          <span class="text-3xl font-semibold text-eco-info" id="val-km-saved">—</span>
          <span class="text-xs text-eco-text-secondary" id="sub-km-saved">vs ruta estandar</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">CO2 evitado</span>
          <span class="text-3xl font-semibold text-eco-green" id="val-co2">—</span>
          <span class="text-xs text-eco-text-secondary">kg por operacion</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Ahorro diario</span>
          <span class="text-3xl font-semibold text-eco-green" id="val-savings">—</span>
          <span class="text-xs text-eco-text-secondary">MXN en combustible</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Reduccion ruta</span>
          <span class="text-3xl font-semibold text-eco-info" id="val-reduction">—</span>
          <span class="text-xs text-eco-text-secondary">eficiencia IA</span>
        </div>
      </section>

      <!-- Mapa: sección dedicada full-width -->
      <section class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">
            Mapa de contenedores — CDMX
          </h2>
          <div class="flex items-center gap-3">
            <span id="map-count" class="text-xs text-eco-text-secondary">—</span>
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-eco-green animate-pulse"></span>
              <span class="text-xs text-eco-text-secondary">En vivo</span>
            </div>
          </div>
        </div>

        <!-- Fleet status row: 4 mini-counters wired to /trucks/ -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs">
          <div class="bg-eco-bg-header rounded-lg px-3 py-2 flex items-center justify-between">
            <span class="text-eco-text-secondary">En ruta</span>
            <span id="fleet-en-route" class="text-eco-info font-semibold">—</span>
          </div>
          <div class="bg-eco-bg-header rounded-lg px-3 py-2 flex items-center justify-between">
            <span class="text-eco-text-secondary">Recolectando</span>
            <span id="fleet-collecting" class="text-eco-warning font-semibold">—</span>
          </div>
          <div class="bg-eco-bg-header rounded-lg px-3 py-2 flex items-center justify-between">
            <span class="text-eco-text-secondary">Regresando</span>
            <span id="fleet-returning" class="text-eco-text-secondary font-semibold">—</span>
          </div>
          <div class="bg-eco-bg-header rounded-lg px-3 py-2 flex items-center justify-between">
            <span class="text-eco-text-secondary">En depósito</span>
            <span id="fleet-idle" class="text-eco-text-secondary font-semibold">—</span>
          </div>
        </div>

        <MapView id="map" height="h-[560px]" />
        <div class="flex flex-wrap gap-4 text-xs text-eco-text-secondary">
          <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-eco-danger inline-block"></span>Critico +80%</span>
          <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-eco-warning inline-block"></span>Medio 50–80%</span>
          <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-eco-green inline-block"></span>Normal &lt;50%</span>
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-eco-info"></span>Camión en ruta</span>
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-eco-warning"></span>Recolectando</span>
        </div>
      </section>

      <!-- Críticos + Predicciones IA lado a lado -->
      <section class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <CriticalList />

        <!-- Predicciones IA (dentro del grid con Críticos) -->
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Predicciones IA — próximas 24h</h2>
            <span class="text-xs bg-eco-green text-white px-2 py-0.5 rounded-full" id="model-badge">Modelo cargando...</span>
          </div>
          <ul id="prediction-list" class="flex flex-col gap-2 max-h-96 overflow-y-auto pr-1">
            <li class="text-xs text-eco-text-secondary">Cargando predicciones...</li>
          </ul>
        </div>
      </section>

      <!-- Rutas + Reportes -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <RouteList />
        <ReportList />
      </section>

      <!-- Metricas por zona -->
      <section class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Desglose por zona</h2>
        <div id="zone-list" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <p class="text-xs text-eco-text-secondary">Cargando zonas...</p>
        </div>
      </section>

    </main>
  </div>
</Layout>

<script>
const API = window.__API__;
const w = window as any;
const L = w.__L__;
const map = w.__maps__?.['map'];
const canvasRenderer = w.__canvas__?.['map'];
const clusterGroup = w.__clusters__?.['map'];

// Keyed store: container_id -> L.CircleMarker. Allows in-place updates
// instead of destroying and recreating 10,000 markers every refresh.
const markerIndex: Map<string, any> = new Map();

function markerColor(fill: number) {
  if (fill >= 0.8) return '#ef4444';
  if (fill >= 0.5) return '#f59e0b';
  return '#16a34a';
}

function popupHtml(c: any) {
  return `<b>${c.container_id}</b><br/>Zona: ${c.zone}<br/>Nivel: ${Math.round(c.fill_level * 100)}%`;
}

async function loadMap() {
  try {
    const res = await fetch(`${API}/api/v1/containers/readings`);
    const containers: any[] = await res.json();

    const countEl = document.getElementById('map-count');
    if (countEl) countEl.textContent = `${containers.length.toLocaleString('es-MX')} contenedores`;

    const seen = new Set<string>();
    const newMarkers: any[] = [];

    for (const c of containers) {
      seen.add(c.container_id);
      const color = markerColor(c.fill_level);
      const existing = markerIndex.get(c.container_id);

      if (existing) {
        // In-place update: no DOM churn
        existing.setStyle({ color, fillColor: color });
        existing.setPopupContent(popupHtml(c));
      } else {
        // Canvas-rendered circle: drawn on a single <canvas> element
        // instead of an individual SVG/DOM node per marker.
        const marker = L.circleMarker([c.latitude, c.longitude], {
          renderer: canvasRenderer,
          radius: 5,
          color: color,
          fillColor: color,
          fillOpacity: 0.85,
          weight: 1.5,
        }).bindPopup(popupHtml(c));
        markerIndex.set(c.container_id, marker);
        newMarkers.push(marker);
      }
    }

    // Add new markers in a single batch to the cluster group
    // (addLayers is significantly faster than N calls to addLayer).
    if (newMarkers.length && clusterGroup) {
      clusterGroup.addLayers(newMarkers);
    } else if (newMarkers.length) {
      newMarkers.forEach(m => m.addTo(map));
    }

    // Remove markers for containers that no longer exist
    for (const [cid, marker] of markerIndex.entries()) {
      if (!seen.has(cid)) {
        if (clusterGroup) clusterGroup.removeLayer(marker);
        else marker.remove();
        markerIndex.delete(cid);
      }
    }
  } catch {}
}

loadMap();
// 30s refresh: fill levels don't change fast enough to justify 10s polls
// at 10K scale — full payload is ~1.5MB per request.
setInterval(loadMap, 30_000);

// ── Fleet layer ───────────────────────────────────────────────────
// Live truck markers on top of the container layer. Polled every 5s
// (matching the simulator tick) so the dashboard sees movement in
// near-real time. Markers are keyed by truck.id and updated in place
// — never recreated — so popups stay open and there's zero DOM churn.

// Tailwind colors per truck status (kept inline so this script doesn't
// need to import the design tokens).
const TRUCK_COLORS: Record<string, string> = {
  en_route:   '#3b82f6',  // info / blue
  collecting: '#f59e0b',  // warning / amber
  returning:  '#64748b',  // muted / slate
  idle:       '#16a34a',  // green / green
  offline:    '#94a3b8',  // gray
};

const STATUS_LABELS: Record<string, string> = {
  en_route:   'En ruta',
  collecting: 'Recolectando',
  returning:  'Regresando',
  idle:       'En depósito',
  offline:    'Desconectado',
};

function truckIcon(status: string): any {
  const color = TRUCK_COLORS[status] ?? '#16a34a';
  return L.divIcon({
    className: '',
    html: `<div style="width:22px;height:22px;border-radius:6px;background:${color};border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:700;font-family:ui-sans-serif,system-ui,-apple-system,sans-serif">T</div>`,
    iconSize: [22, 22],
    iconAnchor: [11, 11],
  });
}

function truckPopup(t: any): string {
  const status = STATUS_LABELS[t.status] ?? t.status;
  const loadPct = Math.round((t.current_load_m3 / t.capacity_m3) * 100);
  const zone = (t.zone || '').replace(/_/g, ' ');
  return `
    <div style="min-width:180px;font-family:ui-sans-serif,system-ui,sans-serif">
      <div style="font-weight:600;margin-bottom:2px">${t.name}</div>
      <div style="font-size:12px;color:#64748b;margin-bottom:6px">${t.id} · ${zone}</div>
      <div style="font-size:12px"><b>Estado:</b> ${status}</div>
      <div style="font-size:12px"><b>Carga:</b> ${t.current_load_m3.toFixed(1)} / ${t.capacity_m3.toFixed(1)} m³ (${loadPct}%)</div>
    </div>`;
}

const truckIndex: Map<string, any> = new Map();

async function loadFleet() {
  try {
    // /trucks/ is unauthenticated read-only — no need for __authFetch__
    const res = await fetch(`${API}/api/v1/trucks/`);
    if (!res.ok) return;
    const trucks: any[] = await res.json();

    // Counters
    const counts = { en_route: 0, collecting: 0, returning: 0, idle: 0 };
    for (const t of trucks) {
      if (t.status in counts) counts[t.status as keyof typeof counts]++;
    }
    setText('fleet-en-route',  counts.en_route);
    setText('fleet-collecting', counts.collecting);
    setText('fleet-returning',  counts.returning);
    setText('fleet-idle',       counts.idle);

    // Markers — in-place updates, added directly to map (NOT clusterGroup)
    // so they stay above the clustered container points and don't get
    // collapsed at low zoom levels.
    const seen = new Set<string>();
    for (const t of trucks) {
      seen.add(t.id);
      const existing = truckIndex.get(t.id);
      if (existing) {
        existing.setLatLng([t.current_lat, t.current_lon]);
        existing.setIcon(truckIcon(t.status));
        existing.setPopupContent(truckPopup(t));
      } else {
        const m = L.marker([t.current_lat, t.current_lon], {
          icon: truckIcon(t.status),
          zIndexOffset: 1000,
        }).bindPopup(truckPopup(t)).addTo(map);
        truckIndex.set(t.id, m);
      }
    }
    // Remove any trucks that vanished from the backend
    for (const [id, m] of truckIndex.entries()) {
      if (!seen.has(id)) { m.remove(); truckIndex.delete(id); }
    }
  } catch {}
}

loadFleet();
setInterval(loadFleet, 5_000);

// ── Metricas ──────────────────────────────────────────────────────
async function loadMetrics() {
  try {
    const res = await fetch(`${API}/api/v1/metrics/`);
    const data = await res.json();

    const sys = data.system;
    setText('val-total', sys.total_containers_monitored);
    setText('sub-total', `${sys.total_sensors_registered} sensores`);
    setText('val-critical', sys.containers_critical);
    setText('val-predicted', sys.containers_predicted_full_24h);
    setText('val-collectors', sys.active_collectors);
    setText('sub-collectors', `de ${sys.total_collectors} totales`);

    const eff = data.efficiency;
    setText('val-km-saved', `${data.environmental.fuel_saved_liters} L`);
    setText('sub-km-saved', `${eff.distance_saved_km} km ahorrados`);
    setText('val-co2', `${data.environmental.co2_avoided_kg} kg`);
    setText('val-savings', `$${data.financial.daily_fuel_savings_mxn}`);
    setText('val-reduction', `${eff.distance_reduction_pct}%`);

    loadZones(data.zones);
  } catch {}
}

function setText(id: string, val: any) {
  const el = document.getElementById(id);
  if (el) el.textContent = String(val);
}

function loadZones(zones: any[]) {
  const el = document.getElementById('zone-list')!;
  if (!zones || zones.length === 0) return;
  el.innerHTML = zones.map(z => {
    const pct = Math.round(z.avg_fill_level * 100);
    const barColor = pct >= 80 ? 'bg-eco-danger' : pct >= 50 ? 'bg-eco-warning' : 'bg-eco-green';
    return `
      <div class="bg-eco-bg-header rounded-lg p-3 flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium text-eco-text-primary capitalize">${z.zone}</span>
          <span class="text-xs text-eco-text-secondary">${z.critical_containers} criticos</span>
        </div>
        <div class="h-2 bg-eco-border rounded-full overflow-hidden">
          <div class="${barColor} h-full rounded-full" style="width:${pct}%"></div>
        </div>
        <div class="flex justify-between text-xs text-eco-text-secondary">
          <span>${z.total_containers} contenedores</span>
          <span>${pct}% promedio</span>
        </div>
      </div>`;
  }).join('');
}

loadMetrics();
setInterval(loadMetrics, 15_000);

// ── Predicciones ───────────────────────────────────────────────────
async function loadPredictions() {
  const list = document.getElementById('prediction-list')!;
  const badge = document.getElementById('model-badge')!;
  try {
    const res = await fetch(`${API}/api/v1/predictions/`);
    if (!res.ok) {
      badge.textContent = 'Modelo entrenando...';
      list.innerHTML = '<li class="text-xs text-eco-text-secondary col-span-2">El modelo de IA esta entrenando con los datos del simulador. Disponible en unos momentos.</li>';
      return;
    }
    const data = await res.json();
    const preds: any[] = data.predictions ?? [];
    badge.textContent = `Modelo activo · ${preds.length} predicciones`;

    const urgent = preds.filter(p => p.estimated_hours_to_full !== null && p.estimated_hours_to_full <= 24);

    if (urgent.length === 0) {
      list.innerHTML = '<li class="text-xs text-eco-text-secondary">Sin contenedores urgentes en las próximas 24h.</li>';
      return;
    }

    // Show top 50 most urgent inside the scrollable container
    const top = urgent.sort((a, b) => (a.estimated_hours_to_full ?? 999) - (b.estimated_hours_to_full ?? 999)).slice(0, 50);
    list.innerHTML = top.map(p => {
      const hrs = p.estimated_hours_to_full?.toFixed(1) ?? '?';
      const pct = Math.round(p.current_fill_level * 100);
      const pred = Math.round(p.predicted_fill_24h * 100);
      const confColor = p.confidence === 'high' ? 'text-eco-danger' : p.confidence === 'medium' ? 'text-eco-warning' : 'text-eco-text-secondary';
      const zoneLabel = (p.zone || '').replace(/_/g, ' ');
      return `
        <li class="flex items-center justify-between rounded-lg bg-eco-bg-header px-3 py-2 gap-2">
          <div class="min-w-0">
            <p class="text-sm font-medium text-eco-text-primary truncate">${p.container_id}</p>
            <p class="text-xs text-eco-text-secondary capitalize truncate">${zoneLabel} · ahora ${pct}% → 24h ${pred}%</p>
          </div>
          <div class="text-right shrink-0">
            <p class="text-sm font-medium text-eco-danger">${hrs}h</p>
            <p class="text-xs ${confColor}">${p.confidence}</p>
          </div>
        </li>`;
    }).join('');
  } catch {}
}

loadPredictions();
setInterval(loadPredictions, 20_000);
</script>
