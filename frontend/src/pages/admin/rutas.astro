---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import { adminNav } from '../../lib/nav';
---

<Layout title="Rutas">
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Rutas" nav={adminNav} />
    <main class="max-w-6xl mx-auto px-4 py-6">
      <h1 class="text-2xl font-semibold text-eco-text-primary mb-4">Gestion de rutas</h1>
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-6">
        <p class="text-sm text-eco-text-secondary">CRUD y visualizacion de rutas de recoleccion (en construccion).</p>
      </div>
    </main>
  </div>
</Layout>
