---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import { adminNav } from '../../lib/nav';
---

<Layout title="Invitar Usuario" requiredRole="admin">
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Invitar usuario" nav={adminNav} />

    <main class="max-w-lg mx-auto px-4 py-6">
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-6 flex flex-col gap-5">
        <div>
          <h1 class="text-xl font-semibold text-eco-text-primary">Invitar usuario</h1>
          <p class="text-sm text-eco-text-secondary mt-1">Crea cuentas para recolectores y administradores</p>
        </div>

        <div id="error-banner" class="alert alert-error" style="display: none;"></div>

        <div id="success-banner" class="alert alert-success text-left" style="display: none;">
          <p class="font-semibold mb-1">Usuario creado exitosamente</p>
          <p class="text-sm mb-0.5">Correo: <strong id="created-email"></strong></p>
          <p class="text-sm">Contrasena temporal: <strong id="created-password" class="font-mono bg-eco-green/10 px-1.5 py-0.5 rounded"></strong></p>
          <p class="text-xs mt-2 opacity-80">Comparte estas credenciales con el usuario.</p>
        </div>

        <form id="invite-form" class="flex flex-col gap-4">
          <div>
            <label for="name" class="block text-sm font-medium text-eco-text-primary mb-1.5">Nombre completo</label>
            <input type="text" id="name" class="input" placeholder="Juan Perez" required />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-eco-text-primary mb-1.5">Correo electronico</label>
            <input type="email" id="email" class="input" placeholder="usuario@correo.com" required />
          </div>

          <div>
            <label for="role" class="block text-sm font-medium text-eco-text-primary mb-1.5">Rol</label>
            <select id="role" class="input" required>
              <option value="collector">Recolector</option>
              <option value="admin">Administrador</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-full mt-2" id="submit-btn">
            Crear usuario
          </button>
        </form>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { apiInviteUser, isAuthenticated, getUser } from '../../lib/api';

  if (!isAuthenticated()) {
    window.location.href = '/auth/login';
  } else {
    const user = getUser();
    if (!user || user.role !== 'admin') {
      window.location.href = '/auth/login';
    }
  }

  const inviteForm = document.getElementById('invite-form');
  const errorBanner = document.getElementById('error-banner');
  const successBanner = document.getElementById('success-banner');
  const createdEmail = document.getElementById('created-email');
  const createdPassword = document.getElementById('created-password');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  if (inviteForm) {
    inviteForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorBanner) errorBanner.style.display = 'none';
      if (successBanner) successBanner.style.display = 'none';

      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const role = (document.getElementById('role') as HTMLSelectElement).value;

      const originalText = submitBtn.innerText;
      submitBtn.innerHTML = `<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Creando...`;
      submitBtn.disabled = true;

      try {
        const data = await apiInviteUser(name, email, role);

        if (createdEmail) createdEmail.textContent = data.email;
        if (createdPassword) createdPassword.textContent = data.temporary_password;
        if (successBanner) successBanner.style.display = 'block';

        (document.getElementById('name') as HTMLInputElement).value = '';
        (document.getElementById('email') as HTMLInputElement).value = '';
      } catch (err: any) {
        if (errorBanner) {
          errorBanner.textContent = err.message;
          errorBanner.style.display = 'block';
        }
      } finally {
        submitBtn.innerText = originalText;
        submitBtn.disabled = false;
      }
    });
  }
</script>
