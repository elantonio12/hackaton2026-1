---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import { collectorNav } from '../../lib/nav';
---

<Layout title="Mi Ruta" requiredRole={['collector', 'admin']}>
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Mi ruta" nav={collectorNav} />

    <main class="max-w-lg mx-auto px-4 py-5 flex flex-col gap-4">

      <!-- Truck identity card -->
      <div id="truck-card" class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-2">
        <div class="flex items-center justify-between gap-2">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Tu camion</span>
          <span id="truck-status-badge" class="text-xs font-semibold px-2 py-0.5 rounded-full bg-eco-bg-header text-eco-text-secondary">—</span>
        </div>
        <div class="flex items-baseline justify-between gap-2">
          <p id="truck-name" class="text-lg font-medium text-eco-text-primary truncate">Cargando...</p>
          <p id="truck-id" class="text-xs text-eco-text-secondary font-mono">—</p>
        </div>
        <p id="truck-zone" class="text-xs text-eco-text-secondary capitalize">—</p>
      </div>

      <!-- Route stats card -->
      <div id="route-status" class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Tu ruta de hoy</span>
          <span id="route-state" class="text-xs text-eco-text-secondary">—</span>
        </div>
        <div class="grid grid-cols-3 gap-3 mt-1">
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-text-primary" id="stop-count">—</p>
            <p class="text-xs text-eco-text-secondary">Paradas</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-info" id="total-km">—</p>
            <p class="text-xs text-eco-text-secondary">Km total</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-warning" id="total-time">—</p>
            <p class="text-xs text-eco-text-secondary">Min aprox</p>
          </div>
        </div>
      </div>

      <!-- Stop list -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Paradas en orden</h2>
          <span id="stop-progress" class="text-xs text-eco-text-secondary">—</span>
        </div>
        <ol id="stop-list" class="flex flex-col gap-2">
          <li class="text-sm text-eco-text-secondary">Cargando ruta...</li>
        </ol>
      </div>

    </main>
  </div>
</Layout>

<script>
  import { apiGetMyRoute, apiGetMyTruck } from '../../lib/api';
  import type { ActiveRouteOut, TruckOut, TruckStatus } from '../../lib/api';

  const TRUCK_POLL_MS = 5000;
  const ROUTE_POLL_MS = 15000;

  const STATUS_LABEL: Record<TruckStatus, string> = {
    idle: 'En descanso',
    en_route: 'En ruta',
    collecting: 'Recolectando',
    returning: 'Volviendo al deposito',
    offline: 'Fuera de linea',
  };

  const STATUS_CLASS: Record<TruckStatus, string> = {
    idle: 'bg-eco-bg-header text-eco-text-secondary',
    en_route: 'bg-eco-info/15 text-eco-info',
    collecting: 'bg-eco-warning/15 text-eco-warning',
    returning: 'bg-eco-green/15 text-eco-green',
    offline: 'bg-eco-danger/15 text-eco-danger',
  };

  function $(id: string): HTMLElement {
    return document.getElementById(id)!;
  }

  function renderTruck(truck: TruckOut) {
    $('truck-name').textContent = truck.name;
    $('truck-id').textContent = truck.id;
    $('truck-zone').textContent = `Zona: ${truck.zone}`;
    const badge = $('truck-status-badge');
    badge.textContent = STATUS_LABEL[truck.status] ?? truck.status;
    badge.className = `text-xs font-semibold px-2 py-0.5 rounded-full ${STATUS_CLASS[truck.status] ?? 'bg-eco-bg-header text-eco-text-secondary'}`;
  }

  function renderRouteEmpty(reason: string) {
    $('route-state').textContent = 'Sin ruta';
    $('stop-count').textContent = '0';
    $('total-km').textContent = '—';
    $('total-time').textContent = '—';
    $('stop-progress').textContent = '';
    $('stop-list').innerHTML = `<li class="text-sm text-eco-text-secondary">${reason}</li>`;
  }

  function renderRoute(route: ActiveRouteOut) {
    const stops = route.stops ?? [];
    const collected = stops.filter(s => s.status === 'collected').length;

    $('route-state').textContent = `Ruta #${route.id}`;
    $('stop-count').textContent = String(stops.length);
    $('total-km').textContent = route.distance_km.toFixed(1);
    $('total-time').textContent = String(Math.round(route.duration_min));
    $('stop-progress').textContent = `${collected} / ${stops.length} recolectadas`;

    if (stops.length === 0) {
      $('stop-list').innerHTML = '<li class="text-sm text-eco-text-secondary">La ruta no tiene paradas asignadas.</li>';
      return;
    }

    $('stop-list').innerHTML = stops.map((s, i) => {
      const pct = Math.round(s.fill_level * 100);
      const isCollected = s.status === 'collected';
      const barColor = pct >= 80 ? 'bg-eco-danger' : pct >= 50 ? 'bg-eco-warning' : 'bg-eco-green';
      const urgency = pct >= 90 ? 'Urgente' : pct >= 80 ? 'Critico' : 'Normal';
      const urgencyColor = pct >= 90 ? 'text-eco-danger' : pct >= 80 ? 'text-eco-warning' : 'text-eco-green';

      const bullet = isCollected
        ? `<span class="w-7 h-7 rounded-full bg-eco-text-secondary text-white text-sm font-bold flex items-center justify-center shrink-0">&#10003;</span>`
        : `<span class="w-7 h-7 rounded-full bg-eco-green text-white text-xs font-bold flex items-center justify-center shrink-0">${i + 1}</span>`;

      const wrapClass = isCollected
        ? 'flex items-center gap-3 bg-eco-bg-header rounded-lg px-3 py-2.5 opacity-60'
        : 'flex items-center gap-3 bg-eco-bg-header rounded-lg px-3 py-2.5';

      const titleClass = isCollected
        ? 'text-sm font-medium text-eco-text-secondary line-through'
        : 'text-sm font-medium text-eco-text-primary';

      return `
        <li class="${wrapClass}">
          ${bullet}
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between">
              <p class="${titleClass}">${s.container_id}</p>
              <span class="text-xs font-medium ${isCollected ? 'text-eco-green' : urgencyColor}">${isCollected ? 'Recolectado' : urgency}</span>
            </div>
            <div class="flex items-center gap-2 mt-1">
              <div class="flex-1 h-1.5 bg-eco-border rounded-full overflow-hidden">
                <div class="${barColor} h-full rounded-full" style="width:${pct}%"></div>
              </div>
              <span class="text-xs text-eco-text-secondary w-8 text-right">${pct}%</span>
            </div>
          </div>
        </li>`;
    }).join('');
  }

  async function pollTruck() {
    try {
      const truck = await apiGetMyTruck();
      renderTruck(truck);
    } catch (err) {
      $('truck-name').textContent = 'Sin camion asignado';
      $('truck-status-badge').textContent = 'Error';
    }
  }

  async function pollRoute() {
    try {
      const route = await apiGetMyRoute();
      if (route) {
        renderRoute(route);
      } else {
        renderRouteEmpty('Esperando asignacion de ruta. Reintentando automaticamente...');
      }
    } catch (err) {
      renderRouteEmpty('Error al cargar la ruta. Reintentando...');
    }
  }

  // Initial load
  pollTruck();
  pollRoute();

  // Polling loops
  let truckTimer: number | null = window.setInterval(pollTruck, TRUCK_POLL_MS);
  let routeTimer: number | null = window.setInterval(pollRoute, ROUTE_POLL_MS);

  // Pause polling when tab hidden
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (truckTimer !== null) { clearInterval(truckTimer); truckTimer = null; }
      if (routeTimer !== null) { clearInterval(routeTimer); routeTimer = null; }
    } else {
      pollTruck();
      pollRoute();
      if (truckTimer === null) truckTimer = window.setInterval(pollTruck, TRUCK_POLL_MS);
      if (routeTimer === null) routeTimer = window.setInterval(pollRoute, ROUTE_POLL_MS);
    }
  });
</script>
