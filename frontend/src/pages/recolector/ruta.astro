---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import { collectorNav } from '../../lib/nav';
---

<Layout title="Mi Ruta" requiredRole={['collector', 'admin']}>
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Mi ruta" nav={collectorNav} />

    <main class="max-w-lg mx-auto px-4 py-5 flex flex-col gap-4">

      <!-- Status card -->
      <div id="route-status" class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Tu ruta de hoy</span>
          <button id="generate-btn" class="btn btn-primary text-xs px-3 py-1">
            Generar ruta
          </button>
        </div>
        <div class="grid grid-cols-3 gap-3 mt-1">
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-text-primary" id="stop-count">—</p>
            <p class="text-xs text-eco-text-secondary">Paradas</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-info" id="total-km">—</p>
            <p class="text-xs text-eco-text-secondary">Km total</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-medium text-eco-warning" id="total-time">—</p>
            <p class="text-xs text-eco-text-secondary">Min aprox</p>
          </div>
        </div>
      </div>

      <!-- Stop list -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Paradas en orden</h2>
        <ol id="stop-list" class="flex flex-col gap-2">
          <li class="text-sm text-eco-text-secondary">Presiona "Generar ruta" para calcular tu recorrido optimizado.</li>
        </ol>
      </div>

    </main>
  </div>
</Layout>

<script>
  const API = window.__API__;

  document.getElementById('generate-btn')!.addEventListener('click', async () => {
    const btn = document.getElementById('generate-btn') as HTMLButtonElement;
    const list = document.getElementById('stop-list')!;
    btn.textContent = 'Calculando...';
    btn.disabled = true;
    list.innerHTML = '<li class="text-sm text-eco-text-secondary">Optimizando ruta con IA...</li>';

    try {
      const res = await (window as any).__authFetch__(`/api/v1/routes/optimize`, {
        method: 'POST',
      });
      const data = await res.json();
      const routes: any[] = data.routes ?? [];

      if (routes.length === 0) {
        list.innerHTML = '<li class="text-sm text-eco-text-secondary">No hay contenedores que requieran recolección.</li>';
        document.getElementById('stop-count')!.textContent = '0';
        return;
      }

      // Use first route as the assigned route for this collector
      const route = routes[0];
      const stops: any[] = route.stops ?? [];

      document.getElementById('stop-count')!.textContent = String(route.containers_visited);
      document.getElementById('total-km')!.textContent = String(route.total_distance_km);
      document.getElementById('total-time')!.textContent = String(route.estimated_time_min);

      // Store for map page
      sessionStorage.setItem('ecoruta_stops', JSON.stringify(stops));

      list.innerHTML = stops.map((s: any, i: number) => {
        const pct = Math.round(s.fill_level * 100);
        const barColor = pct >= 80 ? 'bg-eco-danger' : pct >= 50 ? 'bg-eco-warning' : 'bg-eco-green';
        const urgency = pct >= 90 ? 'Urgente' : pct >= 80 ? 'Crítico' : 'Normal';
        const urgencyColor = pct >= 90 ? 'text-eco-danger' : pct >= 80 ? 'text-eco-warning' : 'text-eco-green';
        return `
          <li class="flex items-center gap-3 bg-eco-bg-header rounded-lg px-3 py-2.5">
            <span class="w-7 h-7 rounded-full bg-eco-green text-white text-xs font-bold flex items-center justify-center shrink-0">${i + 1}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-eco-text-primary">${s.container_id}</p>
                <span class="text-xs font-medium ${urgencyColor}">${urgency}</span>
              </div>
              <div class="flex items-center gap-2 mt-1">
                <div class="flex-1 h-1.5 bg-eco-border rounded-full overflow-hidden">
                  <div class="${barColor} h-full rounded-full" style="width:${pct}%"></div>
                </div>
                <span class="text-xs text-eco-text-secondary w-8 text-right">${pct}%</span>
              </div>
              <p class="text-xs text-eco-text-secondary mt-0.5">${s.latitude.toFixed(4)}, ${s.longitude.toFixed(4)}</p>
            </div>
          </li>`;
      }).join('');
    } catch {
      list.innerHTML = '<li class="text-sm text-eco-danger">Error al generar ruta. Verifica la conexión.</li>';
    } finally {
      btn.textContent = 'Generar ruta';
      btn.disabled = false;
    }
  });
</script>
