---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import MapView from '../../components/MapView.astro';
import { collectorNav } from '../../lib/nav';
---

<Layout title="Mapa de Ruta" requiredRole={['collector', 'admin']}>
  <div class="h-app flex flex-col bg-eco-bg">
    <AppHeader title="Mapa" nav={collectorNav} backHref="/recolector/ruta" />

    <!-- Legend -->
    <div class="px-4 py-2 border-b border-eco-border bg-eco-bg-panel flex items-center gap-3 text-xs text-eco-text-secondary flex-wrap">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-eco-danger inline-block"></span>+80%</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-eco-warning inline-block"></span>50-80%</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-eco-green inline-block"></span>&lt;50%</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-eco-text-secondary inline-block flex items-center justify-center text-white text-[8px]">&#10003;</span>recolectado</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-blue-600 inline-block"></span>tu camion</span>
    </div>

    <!-- Map fills remaining space (cluster off — single route, ~12 stops) -->
    <MapView id="map" height="flex-1" cluster={false} />

    <!-- Bottom info bar -->
    <div id="info-bar" class="bg-eco-bg-panel border-t border-eco-border px-4 py-3 grid grid-cols-4 gap-2 text-sm">
      <div class="text-center">
        <p class="text-xs text-eco-text-secondary">Estado</p>
        <p id="info-status" class="text-eco-text-primary font-medium">—</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-eco-text-secondary">Paradas</p>
        <p id="info-stops" class="text-eco-text-primary font-medium">—</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-eco-text-secondary">Km</p>
        <p id="info-km" class="text-eco-info font-medium">—</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-eco-text-secondary">Min</p>
        <p id="info-time" class="text-eco-warning font-medium">—</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { apiGetMyRoute, apiGetMyTruck } from '../../lib/api';
  import type { ActiveRouteOut, TruckOut, TruckRouteStop, TruckStatus } from '../../lib/api';

  const TRUCK_POLL_MS = 5000;
  const ROUTE_POLL_MS = 15000;

  const STATUS_LABEL: Record<TruckStatus, string> = {
    idle: 'En descanso',
    en_route: 'En ruta',
    collecting: 'Recolectando',
    returning: 'Volviendo',
    offline: 'Sin conexion',
  };

  const L = (window as any).__L__;
  const map = (window as any).__maps__?.['map'];

  // Layers we manage across polls
  let polylineLayer: any = null;
  let truckMarker: any = null;
  const stopMarkers = new Map<string, any>();
  let currentRouteId: number | null = null;
  let didFitBounds = false;

  function $(id: string): HTMLElement {
    return document.getElementById(id)!;
  }

  // ---------------------------------------------------------------------
  // Icons
  // ---------------------------------------------------------------------

  function stopColor(fill: number): string {
    if (fill >= 0.8) return '#ef4444';
    if (fill >= 0.5) return '#f59e0b';
    return '#16a34a';
  }

  function pendingIcon(num: number, color: string) {
    return L.divIcon({
      className: '',
      html: `<div style="width:30px;height:30px;border-radius:50%;background:${color};border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center;color:white;font-size:13px;font-weight:700">${num}</div>`,
      iconSize: [30, 30],
      iconAnchor: [15, 15],
    });
  }

  function collectedIcon() {
    return L.divIcon({
      className: '',
      html: `<div style="width:26px;height:26px;border-radius:50%;background:#94a3b8;border:2px solid white;box-shadow:0 2px 4px rgba(0,0,0,.25);display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:700">&#10003;</div>`,
      iconSize: [26, 26],
      iconAnchor: [13, 13],
    });
  }

  function truckIcon() {
    return L.divIcon({
      className: '',
      html: `<div style="width:34px;height:34px;border-radius:50%;background:#2563eb;border:3px solid white;box-shadow:0 3px 10px rgba(37,99,235,.45);display:flex;align-items:center;justify-content:center;color:white;font-size:18px">&#128666;</div>`,
      iconSize: [34, 34],
      iconAnchor: [17, 17],
    });
  }

  function makeStopMarker(stop: TruckRouteStop, displayIndex: number) {
    const isCollected = stop.status === 'collected';
    const icon = isCollected ? collectedIcon() : pendingIcon(displayIndex, stopColor(stop.fill_level));
    const pct = Math.round(stop.fill_level * 100);
    const popupHtml = `
      <div style="font-size:12px;line-height:1.4">
        <b>Parada ${displayIndex}: ${stop.container_id}</b><br/>
        Nivel: ${pct}%<br/>
        Estado: ${isCollected ? '<b style="color:#16a34a">Recolectado</b>' : 'Pendiente'}
      </div>`;
    return L.marker([stop.latitude, stop.longitude], { icon, zIndexOffset: 100 }).bindPopup(popupHtml);
  }

  // ---------------------------------------------------------------------
  // Render
  // ---------------------------------------------------------------------

  function clearStops() {
    stopMarkers.forEach(m => map.removeLayer(m));
    stopMarkers.clear();
  }

  function clearPolyline() {
    if (polylineLayer) {
      map.removeLayer(polylineLayer);
      polylineLayer = null;
    }
  }

  function drawRoute(route: ActiveRouteOut) {
    // Polyline (real OSRM geometry)
    polylineLayer = L.geoJSON(route.polyline_geojson, {
      style: {
        color: '#16a34a',
        weight: 5,
        opacity: 0.85,
      },
    }).addTo(map);

    // Stops — display index counts pending stops; collected ones get the check icon
    let pendingIndex = 0;
    route.stops.forEach((stop) => {
      if (stop.status !== 'collected') pendingIndex += 1;
      const displayIndex = stop.status === 'collected' ? 0 : pendingIndex;
      const marker = makeStopMarker(stop, displayIndex);
      marker.addTo(map);
      stopMarkers.set(stop.container_id, marker);
    });

    // Fit only the first time the route is rendered
    if (!didFitBounds) {
      try {
        const bounds = polylineLayer.getBounds();
        if (bounds.isValid()) {
          map.fitBounds(bounds.pad(0.15));
          didFitBounds = true;
        }
      } catch {
        /* ignore */
      }
    }
  }

  function updateStops(stops: TruckRouteStop[]) {
    // Walk stops in order; rebuild display indices, swap icons in place
    let pendingIndex = 0;
    for (const stop of stops) {
      if (stop.status !== 'collected') pendingIndex += 1;
      const displayIndex = stop.status === 'collected' ? 0 : pendingIndex;
      const marker = stopMarkers.get(stop.container_id);
      if (!marker) continue;
      const isCollected = stop.status === 'collected';
      marker.setIcon(isCollected ? collectedIcon() : pendingIcon(displayIndex, stopColor(stop.fill_level)));
      const pct = Math.round(stop.fill_level * 100);
      marker.setPopupContent(`
        <div style="font-size:12px;line-height:1.4">
          <b>Parada ${displayIndex || '✓'}: ${stop.container_id}</b><br/>
          Nivel: ${pct}%<br/>
          Estado: ${isCollected ? '<b style="color:#16a34a">Recolectado</b>' : 'Pendiente'}
        </div>`);
    }
  }

  function renderInfoBar(route: ActiveRouteOut | null, truck: TruckOut | null) {
    if (truck) {
      $('info-status').textContent = STATUS_LABEL[truck.status] ?? truck.status;
    }
    if (route) {
      const pending = route.stops.filter(s => s.status !== 'collected').length;
      $('info-stops').textContent = `${pending}/${route.stops.length}`;
      $('info-km').textContent = route.distance_km.toFixed(1);
      $('info-time').textContent = String(Math.round(route.duration_min));
    } else {
      $('info-stops').textContent = '—';
      $('info-km').textContent = '—';
      $('info-time').textContent = '—';
    }
  }

  // ---------------------------------------------------------------------
  // Polling
  // ---------------------------------------------------------------------

  let lastTruck: TruckOut | null = null;
  let lastRoute: ActiveRouteOut | null = null;

  async function refreshTruck() {
    try {
      const truck = await apiGetMyTruck();
      lastTruck = truck;
      const latlng: [number, number] = [truck.current_lat, truck.current_lon];
      if (!truckMarker) {
        truckMarker = L.marker(latlng, { icon: truckIcon(), zIndexOffset: 1000 })
          .bindPopup(`<b>${truck.name}</b><br/>${truck.id}`)
          .addTo(map);
      } else {
        truckMarker.setLatLng(latlng);
      }
      renderInfoBar(lastRoute, truck);
    } catch {
      $('info-status').textContent = 'Sin camion';
    }
  }

  async function refreshRoute() {
    try {
      const route = await apiGetMyRoute();
      if (!route) {
        // No active route — clear everything
        if (currentRouteId !== null) {
          clearPolyline();
          clearStops();
          currentRouteId = null;
          didFitBounds = false;
        }
        lastRoute = null;
        renderInfoBar(null, lastTruck);
        $('info-stops').textContent = 'Sin ruta';
        return;
      }

      if (route.id !== currentRouteId) {
        // New route — full redraw
        clearPolyline();
        clearStops();
        currentRouteId = route.id;
        didFitBounds = false;
        drawRoute(route);
      } else {
        // Same route — only update stop statuses in place
        updateStops(route.stops);
      }
      lastRoute = route;
      renderInfoBar(route, lastTruck);
    } catch {
      // Network error — keep showing last known state
    }
  }

  // Initial load
  (async () => {
    await Promise.all([refreshTruck(), refreshRoute()]);
  })();

  // Polling
  let truckTimer: number | null = window.setInterval(refreshTruck, TRUCK_POLL_MS);
  let routeTimer: number | null = window.setInterval(refreshRoute, ROUTE_POLL_MS);

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (truckTimer !== null) { clearInterval(truckTimer); truckTimer = null; }
      if (routeTimer !== null) { clearInterval(routeTimer); routeTimer = null; }
    } else {
      refreshTruck();
      refreshRoute();
      if (truckTimer === null) truckTimer = window.setInterval(refreshTruck, TRUCK_POLL_MS);
      if (routeTimer === null) routeTimer = window.setInterval(refreshRoute, ROUTE_POLL_MS);
    }
  });
</script>
