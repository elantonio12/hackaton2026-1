---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import MapView from '../../components/MapView.astro';
import { citizenNav } from '../../lib/nav';
---

<Layout title="Mi Zona">
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Mi zona" nav={citizenNav} />

    <main class="max-w-lg mx-auto px-4 py-5 flex flex-col gap-4">

      <!-- Alcaldía detectada vía geolocalización del navegador -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <div class="flex items-center justify-between gap-2">
          <span class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">
            Tu ubicación
          </span>
          <span id="geo-status" class="text-xs text-eco-text-secondary">Detectando...</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-eco-bg-header flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-eco-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <circle cx="12" cy="11" r="3"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p id="zone-name" class="text-lg font-medium text-eco-text-primary truncate">—</p>
            <p id="zone-subtitle" class="text-xs text-eco-text-secondary">Ciudad de México</p>
          </div>
        </div>
        <div id="geo-error" class="hidden rounded-lg bg-eco-bg-header border border-eco-danger p-3 text-xs text-eco-danger">
          <!-- mensaje inyectado vía script -->
        </div>
        <button
          id="geo-retry"
          class="hidden text-xs py-1.5 px-3 rounded-lg border border-eco-border text-eco-text-secondary hover:bg-eco-bg-header"
        >
          Reintentar
        </button>
      </div>

      <!-- Next collection truck -->
      <div id="truck-card" class="hidden bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Recolección en tu zona</span>
          <span id="truck-status-badge" class="text-xs px-2 py-0.5 rounded-full bg-eco-bg-header text-eco-text-secondary">—</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-eco-info/10 flex items-center justify-center shrink-0">
            <span class="text-eco-info font-bold text-sm">T</span>
          </div>
          <div class="flex-1 min-w-0">
            <p id="truck-name" class="text-sm font-medium text-eco-text-primary truncate">—</p>
            <p id="truck-eta" class="text-xs text-eco-text-secondary">Calculando ETA…</p>
          </div>
        </div>
      </div>
      <div id="truck-empty" class="hidden bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-eco-bg-header flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-eco-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-eco-text-primary">Sin recolección activa</p>
          <p class="text-xs text-eco-text-secondary">No hay camiones operando en tu zona ahora.</p>
        </div>
      </div>

      <!-- Zone stats -->
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Contenedores</span>
          <span class="text-2xl font-medium text-eco-text-primary" id="zone-total">—</span>
          <span class="text-xs text-eco-text-secondary">en la zona</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Críticos</span>
          <span class="text-2xl font-medium text-eco-danger" id="zone-critical">—</span>
          <span class="text-xs text-eco-text-secondary">necesitan recolección</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Nivel promedio</span>
          <span class="text-2xl font-medium text-eco-info" id="zone-avg">—</span>
          <span class="text-xs text-eco-text-secondary">de llenado</span>
        </div>
        <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-1">
          <span class="text-xs text-eco-text-secondary uppercase tracking-wide">Estado</span>
          <span class="text-2xl font-medium text-eco-green" id="zone-status">—</span>
          <span class="text-xs text-eco-text-secondary" id="zone-status-sub">del servicio</span>
        </div>
      </div>

      <!-- Map -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Contenedores en tu zona</h2>
        <MapView id="map" height="h-56" />
        <div class="flex gap-4 text-xs text-eco-text-secondary">
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-eco-danger inline-block"></span>Lleno</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-eco-warning inline-block"></span>Medio</span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-eco-green inline-block"></span>Disponible</span>
        </div>
      </div>

      <!-- Container list for zone -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Detalle de contenedores</h2>
        <ul id="container-list" class="flex flex-col gap-2">
          <li class="text-sm text-eco-text-secondary">Cargando...</li>
        </ul>
      </div>

    </main>
  </div>
</Layout>

<script>
  const w = window as any;
  const L = w.__L__;
  const API = window.__API__;
  let currentZone: string | null = null; // resolved from geolocation
  let allContainers: any[] = [];
  const mapInstance: any = w.__maps__?.['map'];
  const canvasRenderer: any = w.__canvas__?.['map'];
  const clusterGroup: any = w.__clusters__?.['map'];

  // Keyed store for in-place updates
  const markerIndex: Map<string, any> = new Map();

  // Alcaldía metadata (must match backend/app/data/cdmx_data.py).
  // Used for geolocation → nearest-centroid → locked zone assignment.
  interface AlcaldiaInfo {
    name: string;
    display: string;
    lat: number;
    lon: number;
  }

  const ALCALDIAS: AlcaldiaInfo[] = [
    { name: 'iztapalapa',             display: 'Iztapalapa',              lat: 19.3574, lon: -99.0667 },
    { name: 'gustavo_a_madero',       display: 'Gustavo A. Madero',       lat: 19.4828, lon: -99.1133 },
    { name: 'alvaro_obregon',         display: 'Álvaro Obregón',          lat: 19.3587, lon: -99.2039 },
    { name: 'tlalpan',                display: 'Tlalpan',                 lat: 19.2926, lon: -99.1707 },
    { name: 'coyoacan',               display: 'Coyoacán',                lat: 19.3467, lon: -99.1617 },
    { name: 'cuauhtemoc',             display: 'Cuauhtémoc',              lat: 19.4326, lon: -99.1472 },
    { name: 'xochimilco',             display: 'Xochimilco',              lat: 19.2574, lon: -99.1035 },
    { name: 'venustiano_carranza',    display: 'Venustiano Carranza',     lat: 19.4342, lon: -99.1056 },
    { name: 'benito_juarez',          display: 'Benito Juárez',           lat: 19.3744, lon: -99.1569 },
    { name: 'azcapotzalco',           display: 'Azcapotzalco',            lat: 19.4872, lon: -99.1852 },
    { name: 'miguel_hidalgo',         display: 'Miguel Hidalgo',          lat: 19.4280, lon: -99.2064 },
    { name: 'iztacalco',              display: 'Iztacalco',               lat: 19.3962, lon: -99.0973 },
    { name: 'tlahuac',                display: 'Tláhuac',                 lat: 19.2819, lon: -99.0072 },
    { name: 'la_magdalena_contreras', display: 'La Magdalena Contreras',  lat: 19.3098, lon: -99.2544 },
    { name: 'cuajimalpa_de_morelos',  display: 'Cuajimalpa de Morelos',   lat: 19.3589, lon: -99.2930 },
    { name: 'milpa_alta',             display: 'Milpa Alta',              lat: 19.1936, lon: -99.0238 },
  ];

  // Max distance from any alcaldía centroid that we'll still consider
  // "inside CDMX" for the nearest-centroid assignment. Chosen generously
  // because some alcaldías are very elongated (Tlalpan, Milpa Alta).
  const MAX_CDMX_DISTANCE_KM = 25;

  // Haversine distance in kilometers
  function haversineKm(lat1: number, lon1: number, lat2: number, lon2: number): number {
    const R = 6371;
    const toRad = (d: number) => (d * Math.PI) / 180;
    const dLat = toRad(lat2 - lat1);
    const dLon = toRad(lon2 - lon1);
    const a = Math.sin(dLat / 2) ** 2 +
              Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
              Math.sin(dLon / 2) ** 2;
    return 2 * R * Math.asin(Math.sqrt(a));
  }

  function nearestAlcaldia(lat: number, lon: number): { alcaldia: AlcaldiaInfo; distanceKm: number } | null {
    let best: AlcaldiaInfo | null = null;
    let bestDist = Infinity;
    for (const a of ALCALDIAS) {
      const d = haversineKm(lat, lon, a.lat, a.lon);
      if (d < bestDist) { bestDist = d; best = a; }
    }
    if (!best || bestDist > MAX_CDMX_DISTANCE_KM) return null;
    return { alcaldia: best, distanceKm: bestDist };
  }

  function markerColor(fill: number) {
    if (fill >= 0.8) return '#ef4444';
    if (fill >= 0.5) return '#f59e0b';
    return '#16a34a';
  }

  // ── Geolocation-based zone detection ─────────────────────────────
  // The user's zone is LOCKED to their actual physical location. This
  // prevents spam/fake reports from users pretending to be in a zone
  // they're not physically present in. Reports sent from usuario/reportes
  // will use the same lat/lon the backend can validate against the
  // reported container's distance.

  const statusEl = document.getElementById('geo-status')!;
  const zoneNameEl = document.getElementById('zone-name')!;
  const zoneSubEl = document.getElementById('zone-subtitle')!;
  const errorEl = document.getElementById('geo-error')!;
  const retryBtn = document.getElementById('geo-retry')! as HTMLButtonElement;

  function showError(title: string, detail: string) {
    statusEl.textContent = 'Sin ubicación';
    zoneNameEl.textContent = '—';
    zoneSubEl.textContent = title;
    errorEl.textContent = detail;
    errorEl.classList.remove('hidden');
    retryBtn.classList.remove('hidden');

    // Lock the rest of the UI: empty stats, no containers
    document.getElementById('zone-total')!.textContent = '—';
    document.getElementById('zone-critical')!.textContent = '—';
    document.getElementById('zone-avg')!.textContent = '—';
    const zStatus = document.getElementById('zone-status')!;
    zStatus.textContent = 'N/D';
    zStatus.className = 'text-2xl font-medium text-eco-text-secondary';
    document.getElementById('zone-status-sub')!.textContent = 'sin ubicación';
    document.getElementById('container-list')!.innerHTML =
      '<li class="text-sm text-eco-text-secondary">Habilita la ubicación del navegador para ver los contenedores cercanos.</li>';
  }

  function resolveLocation() {
    errorEl.classList.add('hidden');
    retryBtn.classList.add('hidden');
    statusEl.textContent = 'Detectando...';
    zoneNameEl.textContent = '—';

    if (!('geolocation' in navigator)) {
      showError('Navegador no soportado', 'Tu navegador no permite compartir ubicación.');
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const { latitude, longitude, accuracy } = pos.coords;
        const match = nearestAlcaldia(latitude, longitude);
        if (!match) {
          showError(
            'Fuera de CDMX',
            'EcoRuta solo opera en la Ciudad de México. Tu ubicación actual está fuera del área de servicio.',
          );
          return;
        }

        currentZone = match.alcaldia.name;
        statusEl.textContent = `± ${Math.round(accuracy)} m`;
        zoneNameEl.textContent = match.alcaldia.display;
        zoneSubEl.textContent = `A ${match.distanceKm.toFixed(1)} km del centro de la alcaldía`;

        // Persist the real user coordinates so usuario/reportes.astro
        // can attach them to any citizen report for backend validation.
        sessionStorage.setItem('ecoruta:user-location', JSON.stringify({
          latitude,
          longitude,
          accuracy,
          alcaldia: match.alcaldia.name,
          display: match.alcaldia.display,
          capturedAt: new Date().toISOString(),
        }));

        // Now that we know the zone, load containers and render.
        loadContainers();
      },
      (err) => {
        if (err.code === err.PERMISSION_DENIED) {
          showError(
            'Permiso denegado',
            'Activa el acceso a ubicación en los permisos del sitio para continuar.',
          );
        } else if (err.code === err.POSITION_UNAVAILABLE) {
          showError(
            'Ubicación no disponible',
            'No pudimos obtener tu posición. Revisa tu conexión o el GPS.',
          );
        } else {
          showError(
            'Tiempo agotado',
            'La solicitud de ubicación tardó demasiado. Intenta de nuevo.',
          );
        }
      },
      { enableHighAccuracy: true, timeout: 10_000, maximumAge: 60_000 },
    );
  }

  retryBtn.addEventListener('click', resolveLocation);

  function renderZone() {
    // If we don't know the user's alcaldía yet, leave the UI empty.
    if (!currentZone) return;
    const zoneContainers = allContainers.filter(c => c.zone === currentZone);
    const critical = zoneContainers.filter(c => c.fill_level >= 0.8);
    const avg = zoneContainers.length > 0
      ? zoneContainers.reduce((s, c) => s + c.fill_level, 0) / zoneContainers.length
      : 0;
    const avgPct = Math.round(avg * 100);

    document.getElementById('zone-total')!.textContent = String(zoneContainers.length);
    document.getElementById('zone-critical')!.textContent = String(critical.length);
    document.getElementById('zone-avg')!.textContent = `${avgPct}%`;

    const statusEl = document.getElementById('zone-status')!;
    const statusSub = document.getElementById('zone-status-sub')!;
    if (critical.length === 0) {
      statusEl.textContent = 'OK';
      statusEl.className = 'text-2xl font-medium text-eco-green';
      statusSub.textContent = 'sin urgencias';
    } else if (critical.length <= 3) {
      statusEl.textContent = 'Atención';
      statusEl.className = 'text-2xl font-medium text-eco-warning';
      statusSub.textContent = `${critical.length} contenedores llenos`;
    } else {
      statusEl.textContent = 'Crítico';
      statusEl.className = 'text-2xl font-medium text-eco-danger';
      statusSub.textContent = `${critical.length} contenedores llenos`;
    }

    // Map: canvas-rendered circle markers, updated in place
    const seen = new Set<string>();
    const newMarkers: any[] = [];
    const latlngs: [number, number][] = [];

    for (const c of zoneContainers) {
      seen.add(c.container_id);
      const color = markerColor(c.fill_level);
      const pct = Math.round(c.fill_level * 100);
      const reportUrl = `/usuario/reportes?container=${encodeURIComponent(c.container_id)}`;
      const popup = `
        <div style="min-width:160px">
          <div style="font-weight:600;margin-bottom:2px">${c.container_id}</div>
          <div style="font-size:12px;color:#64748b;margin-bottom:8px">Nivel: ${pct}%</div>
          <a href="${reportUrl}"
             style="display:inline-block;background:#16a34a;color:white;padding:6px 10px;
                    border-radius:6px;font-size:12px;font-weight:500;text-decoration:none">
            Reportar este contenedor
          </a>
        </div>`;
      latlngs.push([c.latitude, c.longitude]);

      const existing = markerIndex.get(c.container_id);
      if (existing) {
        existing.setStyle({ color, fillColor: color });
        existing.setPopupContent(popup);
      } else {
        const m = L.circleMarker([c.latitude, c.longitude], {
          renderer: canvasRenderer,
          radius: 5,
          color,
          fillColor: color,
          fillOpacity: 0.85,
          weight: 1.5,
        }).bindPopup(popup);
        markerIndex.set(c.container_id, m);
        newMarkers.push(m);
      }
    }

    if (newMarkers.length && clusterGroup) {
      clusterGroup.addLayers(newMarkers);
    } else if (newMarkers.length) {
      newMarkers.forEach(m => m.addTo(mapInstance));
    }

    // Remove markers no longer in the current zone view
    for (const [cid, marker] of markerIndex.entries()) {
      if (!seen.has(cid)) {
        if (clusterGroup) clusterGroup.removeLayer(marker);
        else marker.remove();
        markerIndex.delete(cid);
      }
    }

    if (latlngs.length > 0) {
      mapInstance.fitBounds(L.latLngBounds(latlngs).pad(0.15));
    } else {
      const centroid = ALCALDIAS.find(a => a.name === currentZone);
      mapInstance.setView(centroid ? [centroid.lat, centroid.lon] : [19.432, -99.133], 13);
    }

    // Container list
    const list = document.getElementById('container-list')!;
    if (zoneContainers.length === 0) {
      list.innerHTML = '<li class="text-sm text-eco-text-secondary">Sin contenedores en esta zona.</li>';
      return;
    }

    // Show top 20 containers in the zone (sorted by fill level, most full first).
    // Each row links to the report form for that specific container.
    const sorted = [...zoneContainers].sort((a, b) => b.fill_level - a.fill_level).slice(0, 20);
    list.innerHTML = sorted.map(c => {
      const pct = Math.round(c.fill_level * 100);
      const barColor = pct >= 80 ? 'bg-eco-danger' : pct >= 50 ? 'bg-eco-warning' : 'bg-eco-green';
      const label = pct >= 80 ? 'Lleno' : pct >= 50 ? 'Medio' : 'OK';
      const labelColor = pct >= 80 ? 'text-eco-danger' : pct >= 50 ? 'text-eco-warning' : 'text-eco-green';
      const href = `/usuario/reportes?container=${encodeURIComponent(c.container_id)}`;
      return `
        <li>
          <a href="${href}"
             class="flex items-center gap-3 bg-eco-bg-header hover:bg-eco-bg-panel rounded-lg px-3 py-2 transition-colors">
            <span class="text-sm font-medium text-eco-text-primary w-24 shrink-0 truncate">${c.container_id}</span>
            <div class="flex-1 h-1.5 bg-eco-border rounded-full overflow-hidden">
              <div class="${barColor} h-full rounded-full" style="width:${pct}%"></div>
            </div>
            <span class="text-xs text-eco-text-secondary w-8 text-right">${pct}%</span>
            <span class="text-xs font-medium ${labelColor} w-12 text-right">${label}</span>
          </a>
        </li>`;
    }).join('');

    if (zoneContainers.length > 20) {
      list.innerHTML += `
        <li class="text-xs text-eco-text-secondary text-center pt-1">
          Mostrando los 20 más llenos de ${zoneContainers.length} contenedores en tu alcaldía.
        </li>`;
    }
  }

  // Load data
  async function loadContainers() {
    try {
      const res = await fetch(`${API}/api/v1/containers/readings`);
      allContainers = await res.json();
      renderZone();
    } catch {
      document.getElementById('container-list')!.innerHTML =
        '<li class="text-sm text-eco-danger">Error al cargar datos</li>';
    }
  }

  // ── Next-truck-in-zone card ──────────────────────────────────────
  // Pulls /trucks/?zone={currentZone}, picks the most relevant one
  // (active first, then closest to the user), and shows ETA estimated
  // from haversine distance / 25 km/h average urban speed.
  //
  // 25 km/h is intentionally conservative — the simulator runs at x8
  // demo speed but real garbage trucks crawl with frequent stops, so
  // anything faster would be misleading to citizens.
  const TRUCK_AVG_SPEED_KMH = 25;
  const STATUS_LABELS_TRUCK: Record<string, string> = {
    en_route:   'En ruta',
    collecting: 'Recolectando',
    returning:  'Regresando a depósito',
    idle:       'En depósito',
    offline:    'Desconectado',
  };
  const STATUS_BADGE_CLASS: Record<string, string> = {
    en_route:   'bg-eco-info/15 text-eco-info',
    collecting: 'bg-eco-warning/15 text-eco-warning',
    returning:  'bg-eco-bg-header text-eco-text-secondary',
    idle:       'bg-eco-bg-header text-eco-text-secondary',
    offline:    'bg-eco-bg-header text-eco-text-secondary',
  };

  function pickRelevantTruck(trucks: any[], userLat: number, userLon: number): any | null {
    // Active trucks first (en_route or collecting); among those the closest wins.
    // Falls back to nearest idle/returning if there are no active ones.
    if (trucks.length === 0) return null;
    const active = trucks.filter(t => t.status === 'en_route' || t.status === 'collecting');
    const pool = active.length > 0 ? active : trucks;
    let best: any = null;
    let bestDist = Infinity;
    for (const t of pool) {
      const d = haversineKm(userLat, userLon, t.current_lat, t.current_lon);
      if (d < bestDist) { bestDist = d; best = t; }
    }
    return best ? { truck: best, distanceKm: bestDist } : null;
  }

  async function loadZoneTruck() {
    if (!currentZone) return;
    const loc = JSON.parse(sessionStorage.getItem('ecoruta:user-location') || 'null');
    if (!loc) return;

    const card = document.getElementById('truck-card')!;
    const empty = document.getElementById('truck-empty')!;

    try {
      const res = await fetch(`${API}/api/v1/trucks/?zone=${encodeURIComponent(currentZone)}`);
      if (!res.ok) throw new Error('fetch failed');
      const trucks: any[] = await res.json();

      const pick = pickRelevantTruck(trucks, loc.latitude, loc.longitude);
      if (!pick) {
        card.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }

      const { truck, distanceKm } = pick;
      empty.classList.add('hidden');
      card.classList.remove('hidden');

      const etaMin = Math.max(1, Math.round((distanceKm / TRUCK_AVG_SPEED_KMH) * 60));
      const status = truck.status as string;
      const statusLabel = STATUS_LABELS_TRUCK[status] ?? status;
      const badgeClass = STATUS_BADGE_CLASS[status] ?? 'bg-eco-bg-header text-eco-text-secondary';

      const badge = document.getElementById('truck-status-badge')!;
      badge.textContent = statusLabel;
      badge.className = `text-xs px-2 py-0.5 rounded-full ${badgeClass}`;

      document.getElementById('truck-name')!.textContent = truck.name;

      const etaEl = document.getElementById('truck-eta')!;
      if (status === 'en_route' || status === 'collecting') {
        etaEl.textContent = `A ${distanceKm.toFixed(1)} km · ~${etaMin} min de tu ubicación`;
      } else if (status === 'returning') {
        etaEl.textContent = `Regresando al depósito · a ${distanceKm.toFixed(1)} km`;
      } else {
        etaEl.textContent = `En depósito · disponible cuando arranque ruta`;
      }
    } catch {
      card.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  // Bootstrap: resolve the user's location first, then loadContainers()
  // is called from inside the geolocation success handler. Periodic
  // refresh only runs once we have a zone locked.
  resolveLocation();
  setInterval(() => {
    if (currentZone) loadContainers();
  }, 30_000);

  // Truck card refreshes faster (10s) so the ETA reflects movement.
  setInterval(() => {
    if (currentZone) loadZoneTruck();
  }, 10_000);

  // Trigger an initial truck load right after location resolves.
  // We can't tap into resolveLocation() without rewriting it, so poll
  // until currentZone is set and then fire once.
  const truckBootstrap = setInterval(() => {
    if (currentZone) {
      loadZoneTruck();
      clearInterval(truckBootstrap);
    }
  }, 500);
</script>
