---
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/AppHeader.astro';
import { citizenNav } from '../../lib/nav';
---

<Layout title="Reportar contenedor">
  <div class="h-app overflow-y-auto bg-eco-bg">
    <AppHeader title="Reportes" nav={citizenNav} />

    <main class="max-w-lg mx-auto px-4 py-5 flex flex-col gap-5">

      <!-- Container being reported -->
      <div id="container-card" class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <span class="text-xs text-eco-text-secondary uppercase tracking-wide">
          Reportando contenedor
        </span>
        <div id="container-info" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-eco-bg-header flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-eco-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p id="container-id-label" class="text-lg font-medium text-eco-text-primary truncate">—</p>
            <p id="container-zone-label" class="text-xs text-eco-text-secondary">Cargando...</p>
          </div>
          <span id="container-fill" class="text-sm font-medium text-eco-text-secondary shrink-0">—</span>
        </div>
      </div>

      <!-- Report form -->
      <div id="report-form" class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-4">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Reportar anomalía</h2>

        <div class="flex flex-col gap-1">
          <label for="problem-type" class="text-xs text-eco-text-secondary">Tipo de problema</label>
          <select id="problem-type" class="w-full py-2.5 px-3 rounded-lg text-sm font-medium border border-eco-border bg-eco-bg text-eco-text-primary focus:outline-none focus:border-eco-green">
            <option value="desbordado">Desbordado (basura fuera del contenedor)</option>
            <option value="dañado">Dañado o roto</option>
            <option value="basura_fuera">Basura regada en el piso</option>
            <option value="mal_olor">Mal olor</option>
            <option value="obstruido">Acceso obstruido</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div class="flex flex-col gap-1">
          <label for="description" class="text-xs text-eco-text-secondary">Descripción (opcional)</label>
          <textarea
            id="description"
            rows="3"
            placeholder="Ej: El contenedor está volteado y la basura se está esparciendo..."
            class="w-full py-2.5 px-3 rounded-lg text-sm border border-eco-border bg-eco-bg text-eco-text-primary focus:outline-none focus:border-eco-green resize-none"
          ></textarea>
        </div>

        <button id="submit-btn" class="w-full py-3 rounded-lg bg-eco-green text-white text-sm font-medium hover:bg-eco-green/90 disabled:opacity-50 disabled:cursor-not-allowed">
          Enviar reporte
        </button>

        <p id="form-msg" class="text-xs text-center hidden"></p>
      </div>

      <!-- No container selected state -->
      <div id="empty-state" class="hidden bg-eco-bg-panel border border-eco-border rounded-xl p-6 flex flex-col gap-3 text-center">
        <svg class="w-10 h-10 mx-auto text-eco-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm text-eco-text-primary">Selecciona un contenedor desde el mapa de tu zona.</p>
        <a href="/usuario/info" class="text-xs text-eco-green underline">Ir a mi zona</a>
      </div>

      <!-- Recent reports -->
      <div class="bg-eco-bg-panel border border-eco-border rounded-xl p-4 flex flex-col gap-3">
        <h2 class="text-sm font-medium text-eco-text-secondary uppercase tracking-wide">Reportes recientes</h2>
        <ul id="report-list" class="flex flex-col gap-2">
          <li class="text-sm text-eco-text-secondary">Cargando...</li>
        </ul>
      </div>

    </main>
  </div>
</Layout>

<script>
  const API = window.__API__;

  const PROBLEM_LABELS: Record<string, string> = {
    desbordado: 'Desbordado',
    dañado: 'Dañado',
    basura_fuera: 'Basura fuera',
    mal_olor: 'Mal olor',
    obstruido: 'Acceso obstruido',
    otro: 'Otro',
  };

  function getContainerIdFromQuery(): string | null {
    const params = new URLSearchParams(window.location.search);
    return params.get('container');
  }

  function getUserLocation(): { latitude: number; longitude: number; alcaldia: string } | null {
    const raw = sessionStorage.getItem('ecoruta:user-location');
    if (!raw) return null;
    try {
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function showMsg(text: string, isError: boolean) {
    const el = document.getElementById('form-msg')!;
    el.textContent = text;
    el.className = `text-xs text-center ${isError ? 'text-eco-danger' : 'text-eco-green'}`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 5000);
  }

  async function loadContainerDetails(containerId: string) {
    try {
      const res = await fetch(`${API}/api/v1/containers/readings/${encodeURIComponent(containerId)}`);
      if (!res.ok) throw new Error('not found');
      const c = await res.json();
      if (c.error) throw new Error(c.error);
      document.getElementById('container-id-label')!.textContent = c.container_id;
      const zoneLabel = (c.zone || '').replace(/_/g, ' ');
      document.getElementById('container-zone-label')!.textContent = `Alcaldía: ${zoneLabel}`;
      const pct = Math.round(c.fill_level * 100);
      const fillEl = document.getElementById('container-fill')!;
      fillEl.textContent = `${pct}%`;
      fillEl.className = `text-sm font-medium shrink-0 ${
        pct >= 80 ? 'text-eco-danger' : pct >= 50 ? 'text-eco-warning' : 'text-eco-green'
      }`;
    } catch {
      document.getElementById('container-id-label')!.textContent = containerId;
      document.getElementById('container-zone-label')!.textContent = 'Contenedor no encontrado';
      document.getElementById('container-fill')!.textContent = '—';
    }
  }

  async function submitReport(containerId: string) {
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const problemType = (document.getElementById('problem-type') as HTMLSelectElement).value;
    const description = (document.getElementById('description') as HTMLTextAreaElement).value.trim();

    const loc = getUserLocation();
    if (!loc) {
      showMsg('No tenemos tu ubicación. Abre "Mi zona" primero para detectarla.', true);
      return;
    }

    btn.textContent = 'Enviando...';
    btn.disabled = true;

    try {
      const res = await fetch(`${API}/api/v1/reports/citizen`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          container_id: containerId,
          problem_type: problemType,
          description: description || '',
          user_latitude: loc.latitude,
          user_longitude: loc.longitude,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        showMsg(data.detail || 'Error al enviar reporte', true);
        return;
      }

      showMsg(`Reporte enviado (a ${data.distance_m} m del contenedor)`, false);
      (document.getElementById('description') as HTMLTextAreaElement).value = '';
      loadReports();
    } catch {
      showMsg('Error de red. Intenta de nuevo.', true);
    } finally {
      btn.textContent = 'Enviar reporte';
      btn.disabled = false;
    }
  }

  async function loadReports() {
    const list = document.getElementById('report-list')!;
    try {
      const res = await fetch(`${API}/api/v1/reports/citizen?limit=10`);
      const data: any[] = await res.json();

      if (data.length === 0) {
        list.innerHTML = '<li class="text-sm text-eco-text-secondary">Sin reportes por el momento.</li>';
        return;
      }

      list.innerHTML = data.map(r => {
        const problemLabel = PROBLEM_LABELS[r.problem_type] ?? r.problem_type;
        const zoneLabel = (r.zone || '').replace(/_/g, ' ');
        const desc = r.description && r.description !== '(sin descripción)'
          ? `<p class="text-xs text-eco-text-secondary mt-1 line-clamp-2">${r.description}</p>`
          : '';
        return `
          <li class="bg-eco-bg-header rounded-lg px-3 py-2.5">
            <div class="flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-eco-text-primary truncate">${r.container_id}</span>
              <span class="text-xs text-eco-warning shrink-0">${problemLabel}</span>
            </div>
            <p class="text-xs text-eco-text-secondary capitalize">${zoneLabel}</p>
            ${desc}
          </li>`;
      }).join('');
    } catch {
      list.innerHTML = '<li class="text-sm text-eco-danger">Error al cargar reportes</li>';
    }
  }

  // ── Bootstrap ──────────────────────────────────────────────────────
  const containerId = getContainerIdFromQuery();

  if (!containerId) {
    // No container in query string — show empty state and hide form
    document.getElementById('container-card')!.classList.add('hidden');
    document.getElementById('report-form')!.classList.add('hidden');
    document.getElementById('empty-state')!.classList.remove('hidden');
  } else {
    loadContainerDetails(containerId);
    document.getElementById('submit-btn')!.addEventListener('click', () => {
      submitReport(containerId);
    });
  }

  loadReports();
</script>
