---
import '../styles/global.css';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import Problem from '../components/landing/Problem.astro';
import Solution from '../components/landing/Solution.astro';
import Metrics from '../components/landing/Metrics.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import Architecture from '../components/landing/Architecture.astro';
import Market from '../components/landing/Market.astro';
import ODS from '../components/landing/ODS.astro';
import Team from '../components/landing/Team.astro';
import CTA from '../components/landing/CTA.astro';
import Footer from '../components/landing/Footer.astro';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Sistema de gestion de residuos con IoT, IA y rutas dinamicas. Reduce 25% de km recorridos y 129 kg de CO2 diarios." />
    <meta name="theme-color" content="#16a34a" />
    <meta property="og:title" content="EcoRuta — Recoleccion Inteligente de Residuos para CDMX" />
    <meta property="og:description" content="Sistema de gestion de residuos con IoT, IA y rutas dinamicas." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>EcoRuta — Recoleccion Inteligente de Residuos para CDMX</title>
  </head>

  <body class="bg-white text-eco-text-primary font-sans antialiased overflow-x-hidden">
    <Nav />
    <Hero />
    <Problem />
    <Solution />
    <Metrics />
    <HowItWorks />
    <Architecture />
    <Market />
    <ODS />
    <Team />
    <CTA />
    <Footer />
  </body>
</html>

<!-- Fade-up animation on scroll -->
<style>
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>
